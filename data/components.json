  "Accordeon": {
    "desc": "Un composant pliant (Spoiler) avec JS fait maison",
    "html-code": "<div class=\"acc-wrap\"><button id=\"btn-{*identifiant*}\" class=\"acc-btn-{*identifiant*}\">{*titre*}</button><div id=\"content-{*identifiant*}\" class=\"acc-content-{*identifiant*}\">{*contenu*}</div></div>",
    "css-code": ".acc-btn-{*identifiant*} { width: 100%; padding: 10px; background: #eee; border: none; text-align: left; cursor: pointer; font-weight: bold; } .acc-content-{*identifiant*} { display: none; padding: 15px; border: 1px solid #eee; border-top: none; }",
    "js-code": "document.getElementById('btn-{*identifiant*}').addEventListener('click', function() { var el = document.getElementById('content-{*identifiant*}'); if(el.style.display === 'block'){ el.style.display = 'none'; } else { el.style.display = 'block'; } });",
    "lib": [],
    "param": {
      "identifiant": [
        "identifiant",
        "text",
        "acc1"
      ],
      "titre": [
        "titre",
        "text",
        "Voir plus de détails"
      ],
      "contenu": [
        "contenu",
        "empty"
      ]
    }
  },
