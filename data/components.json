  "ModalSimple": {
    "desc": "Une fenêtre modale simple avec ouverture/fermeture",
    "html-code": "<div><button id=\"open-{*identifiant*}\">Ouvrir {*titre*}</button><div id=\"modal-{*identifiant*}\" class=\"modal-overlay-{*identifiant*}\" style=\"display:none;\"><div class=\"modal-box\"><span id=\"close-{*identifiant*}\" style=\"float:right; cursor:pointer;\">&times;</span><h2>{*titre*}</h2><div>{*contenu*}</div></div></div></div>",
    "css-code": ".modal-overlay-{*identifiant*} { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; justify-content: center; align-items: center; } .modal-overlay-{*identifiant*} .modal-box { background: #fff; padding: 20px; border-radius: 5px; min-width: 300px; max-width: 80%; }",
    "js-code": "var m = document.getElementById('modal-{*identifiant*}'); var btn = document.getElementById('open-{*identifiant*}'); var span = document.getElementById('close-{*identifiant*}'); btn.onclick = function() { m.style.display = 'flex'; }; span.onclick = function() { m.style.display = 'none'; }; window.onclick = function(event) { if (event.target == m) { m.style.display = 'none'; } };",
    "lib": [],
    "param": {
      "identifiant": [
        "identifiant",
        "text",
        "mod1"
      ],
      "titre": [
        "titre",
        "text",
        "Information"
      ],
      "contenu": [
        "contenu",
        "empty"
      ]
    }
  },
